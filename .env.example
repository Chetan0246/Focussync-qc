# FocusSync Environment Configuration
# Copy this file to .env and fill in the values

# ========================
# Server Configuration
# ========================

# Port for the backend server
PORT=5000

# Node environment (development or production)
NODE_ENV=development

# ========================
# MongoDB Configuration
# ========================

# MongoDB connection string
# Local:  mongodb://localhost:27017/focussync
# Atlas:  mongodb+srv://<username>:<password>@cluster.mongodb.net/focussync?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/focussync

# ========================
# JWT Configuration
# ========================

# Secret key for signing JWT tokens (generate a strong random string for production)
# Recommended: openssl rand -base64 64
JWT_SECRET=focussync-secret-key-change-in-production

# Token expiration (default: 7 days)
JWT_EXPIRES_IN=7d

# ========================
# CORS Configuration
# ========================

# Allowed frontend origin(s) (comma-separated for multiple)
CLIENT_URL=http://localhost:3000

# ========================
# Client Configuration (React .env)
# ========================
# NOTE: These go in client/.env, NOT in this file.
# REACT_APP_API_URL=http://localhost:5000
